{
  "name": "@dropai/node-knowledge-graph",
  "version": "0.0.1",
  "private": true,
  "dropai": {
    "node": {
      "type": "knowledge-graph",
      "category": "Knowledge",
      "label": "Knowledge Graph",
      "description": "Extract subject-predicate-object triples from text and render an interactive graph",
      "color": "#ffb454",
      "inputs": 1,
      "outputs": 1,
      "runner": "python",
      "runtime": "kg_node:run",
      "defaults": {
        "text": "",
        "model": "gpt-4o-mini",
        "baseUrl": "https://api.openai.com/v1",
        "chunkSize": 200,
        "overlap": 40
      }
    }
  }
}

{
  "name": "@dropai/node-llm-claude",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./runtime.js",
  "dropai": {
    "node": {
      "type": "llm-claude",
      "category": "AI",
      "label": "Claude LLM",
      "description": "Single-shot chat completion via Claude (requires a DropAI token)",
      "color": "#d97706",
      "inputs": 1,
      "outputs": 1,
      "runner": "node",
      "runtime": "./runtime.js",
      "defaults": {
        "model": "claude-sonnet-4-6",
        "dropaiToken": "",
        "systemPrompt": "You are a helpful assistant.",
        "userPromptTemplate": "{{input}}",
        "temperature": 0.7,
        "maxTokens": 1024
      }
    }
  }
}
